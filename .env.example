###############################################################################
# Server
###############################################################################
PORT=3000
LOG_LEVEL=info

###############################################################################
# Internal service auth (dashboard -> API)
###############################################################################
INTERNAL_SERVICE_SECRET=change_me_to_a_long_random_string

###############################################################################
# Database (Postgres / Supabase)
# - If DATABASE_URL is not set, the server still starts, but task execution
#   endpoints will return 503 (DB not configured).
###############################################################################
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchest

# Supabase notes:
# - Prefer the "Transaction pooler" connection string if your network is IPv4-only
#   (many `db.<ref>.supabase.co` hosts are IPv6-only).
# - This app enables SSL automatically for *.supabase.co / *.supabase.com hosts.

###############################################################################
# Multi-tenant defaults (used by Slack intake if no tenant mapping exists yet)
###############################################################################
DEFAULT_CLIENT_NAME=Acme Inc
DEFAULT_AGENT_NAME=Orchest Engineer

###############################################################################
# OpenAI-compatible API (optional; mocked if OPENAI_API_KEY not set)
###############################################################################
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

###############################################################################
# Slack (MVP)
###############################################################################
# Multi-bot model: create one Slack app per bot persona (Ava, Ben, etc).
# Each Slack app has its own Client ID/Secret and Signing Secret, but they can
# share the same redirect URL + events URL (pointing at the same Orchest API).
#
# Example:
# SLACK_BOT_KEYS=ava,ben,priya,sofia,amira
# SLACK_AVA_CLIENT_ID=...
# SLACK_AVA_CLIENT_SECRET=...
# SLACK_AVA_SIGNING_SECRET=...
SLACK_BOT_KEYS=ava,ben,priya,sofia,amira

SLACK_AVA_CLIENT_ID=
SLACK_AVA_CLIENT_SECRET=
SLACK_AVA_SIGNING_SECRET=

SLACK_BEN_CLIENT_ID=
SLACK_BEN_CLIENT_SECRET=
SLACK_BEN_SIGNING_SECRET=

SLACK_PRIYA_CLIENT_ID=
SLACK_PRIYA_CLIENT_SECRET=
SLACK_PRIYA_SIGNING_SECRET=

SLACK_SOFIA_CLIENT_ID=
SLACK_SOFIA_CLIENT_SECRET=
SLACK_SOFIA_SIGNING_SECRET=

SLACK_AMIRA_CLIENT_ID=
SLACK_AMIRA_CLIENT_SECRET=
SLACK_AMIRA_SIGNING_SECRET=

# Set this to your API callback URL (Fly), e.g.
# SLACK_REDIRECT_URI=https://<your-fly-app>.fly.dev/integrations/slack/callback
SLACK_REDIRECT_URI=

# Used to redirect back after Slack install completes.
# Example: https://<your-vercel-app>.vercel.app
DASHBOARD_BASE_URL=

