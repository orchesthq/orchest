###############################################################################
# Dashboard (Next.js)
###############################################################################
NEXTAUTH_URL=http://orchesthq.com
NEXTAUTH_SECRET=change_me_to_a_long_random_string

# Uses the same Postgres as the API (users + client_memberships tables).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchest

# Dashboard -> API (internal)
API_BASE_URL=http://api.orchesthq.com
INTERNAL_SERVICE_SECRET=dev_internal_secret_change_me

# Email delivery (Resend)
RESEND_API_KEY=resend_api_key_change_me
EMAIL_FROM=Orchest <noreply@orchesthq.com>

# Optional explicit public base URL for links in emails.
APP_BASE_URL=http://orchesthq.com