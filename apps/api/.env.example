###############################################################################
# Internal service auth (dashboard -> API)
###############################################################################
INTERNAL_SERVICE_SECRET=change_me_to_a_long_random_string

###############################################################################
# Database (Postgres / Supabase)
# - If DATABASE_URL is not set, the server still starts, but task execution
#   endpoints will return 503 (DB not configured).
###############################################################################
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchest

# Set this to your API callback URL
SLACK_REDIRECT_URI=http://api.orchesthq.com:3000/integrations/slack/callback

# Used to redirect back after Slack install completes.
DASHBOARD_BASE_URL=https://orchesthq.com

###############################################################################
# Agent runtime
###############################################################################
# Agent engine:
# - legacy: plan -> execute (structured actions) -> summarize
# - react:  ReAct loop (tool calling per step) + self-critique
ORCHEST_AGENT_ENGINE=react

# Safety guardrails for ReAct loop (only used by ORCHEST_AGENT_ENGINE=react).
ORCHEST_AGENT_MAX_ITERATIONS=20
ORCHEST_AGENT_MAX_TOOL_CALLS=30

# Slack debug logging
# - Set to 1 to include verbose Slack API error details and extra Slack routing logs.
# - Unset/0 keeps logs concise.
ORCHEST_SLACK_DEBUG=0